msgstr ""
"Are you sure you want to\n"
"quit this great game?"

msgid "LOADNET"
msgstr ""
"You can't do load while in a net game!\n"
"\n"
"Press a key."

msgid "QLOADNET"
msgstr ""
"You can't quickload during a netgame!\n"
"\n"
"Press a key."

msgid "QSAVESPOT"
msgstr ""
"You haven't picked a quicksave slot yet!\n"
"\n"
"Press a key."

msgid "NEWGAME"
msgstr ""
"You can't start a new game\n"
"while in a network game.\n"
"\n"
"Press a key."

msgid "NIGHTMARE"
msgstr ""
"Are you sure? This skill level\n"
"isn't even remotely fair.\n"
"\n"
"Press Y or N."

msgid "SWSTRING"
msgstr ""
"This is the shareware version of Doom.\n"
"\n"
"You need to order the entire trilogy.\n"
"\n"
"Press a key."

msgid "NETEND"
msgstr ""
"You can't end a netgame!\n"
"\n"
"Press a key."

msgid "ENDGAME"
msgstr ""
"Are you sure you want to end the game?\n"
"\n"
"Press Y or N."

