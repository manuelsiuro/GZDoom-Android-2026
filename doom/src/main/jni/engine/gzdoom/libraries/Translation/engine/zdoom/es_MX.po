msgid "SWSTRING"
msgstr "Solo disponible en la versión completa"

msgid "DOSY"
msgstr "(Presiona Y para salir)"

msgid "QUITMSG1"
msgstr ""
"¡No te vayas, aún quedan demonios\n"
"por los que exterminar!"

msgid "QUITMSG2"
msgstr ""
"¡Larguémonos—es un mar\n"
"de sangre aqui!"

msgid "QUITMSG3"
msgstr ""
"Yo que tú no me voy.\n"
"DOS es muchísimo peór."

msgid "QUITMSG4"
msgstr ""
"Intentas decir que prefieres DOS\n"
"antes que a mí, ¿Verdad?"

msgid "QUITMSG5"
msgstr ""
"¡Aún no te vayas—hay un\n"
"demonio por esa esquina!"

msgid "QUITMSG6"
msgstr ""
"La proxima vez que vengas\n"
"aqui acabaré contigo."

msgid "QUITMSG7"
msgstr "Vete fuera de aqui. No me importa."

# More info here.
msgid "QUITMSG8"
msgstr ""
"Si intentas salir\n"
"del juego, hay tabla!"

# A “dimensional shambler” is a creature appearing in the works of H. P.
# Lovecraft.
msgid "QUITMSG9"
msgstr ""
"¡No te vayas ahora, hay un\n"
"shambler dimensional esperando\n"
"en la línea de comandos de DOS!"

msgid "QUITMSG10"
msgstr ""
"Vete y regresa a tus\n"
"aburridos programas."

msgid "QUITMSG11"
msgstr ""
"¡Si fuera tu jefe, te retaría a\n"
"un deathmatch en un minuto!"

msgid "QUITMSG12"
msgstr ""
"Mira, amigo. ¡Te vas ahora y\n"
"pierdes el recuento de cadáveres!"

msgid "QUITMSG13"
msgstr ""
"Vete. Cuando regreses te\n"
"esperaré con un bate."

msgid "QUITMSG14"
msgstr ""
"Tienes suerte de que no te\n"
"golpee por pensar en irte."

msgid "QUITMSG15"
msgstr ""
"¿A dónde vas?\n"
"¿Qué hay de la rebelión?"

msgid "QUITMSG16"
msgstr ""
"Masacre interruptus…\n"
"¡Qué estafa!"

msgid "QUITMSG17"
msgstr ""
"Pero, eres mi esperanza\n"
"—¡Mi única oportunidad!"

msgid "QUITMSG18"
msgstr "Nadie abandona a Blackbird."

msgid "QUITMSG19"
msgstr "Creí que eras diferente…"

msgid "QUITMSG20"
msgstr "¡Bien, solo mata y corre!"

msgid "QUITMSG21"
msgstr ""
"Podrás correr…\n"
"Pero no esconderte…"

msgid "QUITMSG22"
msgstr ""
"¿Eh, qué pasa, mami\n"
"te llama para cenar?"

msgid "QUITMSG23"
msgstr ""
"¡No te vayas, aún quedan\n"
"flemoids a la deriva!"

msgid "QUITMSG24"
msgstr ""
"No te rindas… ¡o los\n"
"flemoides van a tener ventaja!"

msgid "QUITMSG25"
msgstr ""
"No te vayas.\n"
"¡Necesitamos tu ayuda!"

msgid "QUITMSG26"
msgstr ""
"Espero que tomes el descanso\n"
"disfrutando de Chex® Party Mix."

msgid "QUITMSG27"
msgstr ""
"¡No te salgas!\n"
"¡Necesitamos tu ayuda!"

msgid "QUITMSG28"
msgstr ""
"¡No abandones la Federación\n"
"Intergaláctica de Cereales!"

msgid "QUITMSG29"
msgstr ""
"¡El verdadero Guerrero Chex®\n"
"no se rendiría tan rápido!"

