# “Press any key.”
msgid "LOADNET"
msgstr ""
"¡No puedes cargar en multijugador!\n"
"\n"
"Presiona cualquier tecla."

msgid "QLOADNET"
msgstr ""
"¡No puedes cargar rápido en multijugador!\n"
"\n"
"Presiona cualquier tecla."

msgid "QSAVESPOT"
msgstr ""
"¡No has elegido una ranura para guardar rápido!\n"
"\n"
"Presiona cualquier tecla."

msgid "NEWGAME"
msgstr ""
"No puedes iniciar una nueva\n"
"partida en multijugador.\n"
"\n"
"Presiona cualquier tecla."

msgid "NIGHTMARE"
msgstr ""
"¿Estás seguro? Esta dificultad\n"
"no tendrá piedad en ti.\n"
"\n"
"Presiona Y o N."

msgid "SWSTRING"
msgstr ""
"Esta es la versión shareware de Doom.\n"
"\n"
"Necesitas ordenar la trilogía entera.\n"
"\n"
"Presiona cualquier tecla."

msgid "NETEND"
msgstr ""
"No puedes terminar una partida multijugador!\n"
"\n"
"Presiona cualquier tecla."

msgid "ENDGAME"
msgstr ""
"¿Estás seguro de terminar esta partida?\n"
"\n"
"Presiona Y o N."

msgid "RAVENQUITMSG"
msgstr "¿Estás seguro de que quieres irte?"

