msgid "TXT_RPLY2_SCRIPT33_D7580_HEALI"
msgstr "Penyembuhan"

msgid "TXT_RYES2_SCRIPT33_D7580_THERE"
msgstr "Ini dia. Jaga diri baik-baik."

msgid "TXT_RNO2_SCRIPT33_D7580_WELLM"
msgstr "Mungkin kamu mampu membeli beberapa tambalan medis?"

msgid "TXT_DLG_SCRIPT33_D9096_HELLO"
msgstr ""
"Halo kawan, aku belum pernah melihatmu di sini sebelumnya. Yang bisa "
"kukatakan adalah berhati-hatilah kalau jadi kamu, banyak hal yang sedang "
