msgid "TXT_RYES0_SCRIPT32_D3032_IWASF"
msgstr "Aku dijebak."

msgid "TXT_DLG_SCRIPT32_D4548_HARRI"
msgstr ""
"Harris mengatakan bahwa aku sedang merencanakan pembunuhan Gubernur. Aku "
"tidak akan pernah menyakiti siapa pun."

