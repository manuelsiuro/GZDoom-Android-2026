msgid "TXT_RPLY0_SCRIPT10_D1516_IMGON"
msgstr "Aku akan butuh lebih banyak perbekalan."

msgid "TXT_DLG_SCRIPT10_D3032_HERES"
msgstr "Ini emas. Pergi temui dokter dan pelatih senjata, lalu bergerak!"

msgid "TXT_RPLY0_SCRIPT10_D3032_RIGHT"
msgstr "Siap!"

msgid "TXT_DLG_SCRIPT10_D4548_FIGHT"
msgstr "Berjuanglah untuk Front dan kebebasan. Bergerak."

msgid "TXT_DLG_SCRIPT10_D6064_WHATP"
msgstr ""
"Apa yang membuatmu kembali? Apakah kamu terluka? Tidak ada waktu yang "
"terbuang, lanjutkan misimu. Lengkapi Sigil."

msgid "TXT_RPLY0_SCRIPT10_D6064_THEOR"
msgstr "Oracle mengatakan kamu harus mati!"

msgid "TXT_DLG_SCRIPT10_D7580_IHAVE"
msgstr ""
"Aku telah bersumpah untuk kebebasan. Oracle-lah yang memegang bagian ketiga. "
"Di sanalah pengkhianatmu."

msgid "TXT_RPLY0_SCRIPT10_D7580_THEOR"
msgstr "Kalau begitu Oracle harus mati!"

msgid "TXT_RPLY1_SCRIPT10_D7580_ITHIN"
msgstr "Kurasa kamulah pengkhianatnya!"

