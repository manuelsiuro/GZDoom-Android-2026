msgid "TXT_DLG_SCRIPT04_D13644_GETBA"
msgstr "Kembali bekerja, sekarang!"

msgid "TXT_DLG_SCRIPT04_D15160_GETBA"
msgstr "Kembali bekerja, sekarang!"

msgid "TXT_DLG_SCRIPT04_D16676_WEVEB"
msgstr ""
"Kita sudah bekerja tanpa henti selama berminggu-minggu tanpa istirahat. "
"Kurasa Ordo sedang merencanakan serangan penumpasan terhadap Front."

msgid "TXT_DLG_SCRIPT04_D18192_OHDAM"
msgstr ""
"Sial. Gubernur yang mengutusmu. Aku memang akan memberinya bagiannya, "
