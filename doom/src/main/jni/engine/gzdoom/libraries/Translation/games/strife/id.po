msgid "TXT_DLG_SCRIPT05_D7580_OVERM"
msgstr "Hanya kalau aku sudah mati!"

msgid "TXT_RPLY0_SCRIPT05_D7580_GREAT"
msgstr "Ide yang bagus!"

msgid "TXT_DLG_SCRIPT05_D9096_SHACK"
msgstr "Belenggu atau rantai, aku ingin kamu tetap di sini."

msgid "TXT_DLG_SCRIPT05_D10612_IDONT"
msgstr ""
"Aku tidak tahu bagaimana caramu melewati para penjaga dan Sipir, tapi semoga "
