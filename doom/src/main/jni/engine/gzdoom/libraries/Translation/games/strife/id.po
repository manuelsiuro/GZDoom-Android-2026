msgid "TXT_DLG_SCRIPT02_D13644_ICANT"
msgstr ""
"Tidak percaya aku terjebak dengan tugas ini. Mereka bilang ada sesuatu yang "
"jahat keluar dari pintu got ini... Sekarang aku harus berdiri di sini sampai "
"ia muncul lagi!"

msgid "TXT_RPLY0_SCRIPT02_D13644_WHATG"
msgstr "Pintu yang mana?"

msgid "TXT_RYES0_SCRIPT02_D13644_THESE"
msgstr "Pintu luapan saluran pembuangan."

