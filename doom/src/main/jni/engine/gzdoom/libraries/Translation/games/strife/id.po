msgid "TXT_DLG_SCRIPT07_D0_WHATT"
msgstr "Apa-apaan ini? Siapa yang membuka gerbangnya? Bunyikan alarm!!!"

msgid "TXT_DLG_SCRIPT07_D1516_THERE"
msgstr ""
"Ada jalan lain masuk ke saluran pembuangan, tekan sakelar itu lalu naik dan "
"kuras tangki pemulihan."

msgid "TXT_DLG_SCRIPT07_D3032_WHATT"
msgstr "Apa masalahmu. Kalau Programmer naik dari ruang audiensinya, kamu mati."

