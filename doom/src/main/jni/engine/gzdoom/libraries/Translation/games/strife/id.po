msgid "TXT_RYES0_SCRIPT33_D1516_IFYOU"
msgstr "Kalau kamu memukul seseorang, itu tidak akan memicu alarm."

msgid "TXT_RNO0_SCRIPT33_D1516_IWONT"
msgstr "Aku tidak akan memberitahumu apa-apa secara gratis!"

msgid "TXT_DLG_SCRIPT33_D3032_IVEAL"
msgstr "Aku sudah memberitahumu semua yang aku tahu."

msgid "TXT_DLG_SCRIPT33_D4548_HELLO"
msgstr "Halo kawan. Apa yang bisa kuberikan untukmu?"

msgid "TXT_RPLY0_SCRIPT33_D4548_ELECT"
msgstr "Anak panah listrik"

msgid "TXT_RYES0_SCRIPT33_D4548_ONEQU"
