msgid "TXT_DLG_SCRIPT02_D22740_IHOPE"
msgstr ""
"Semoga Macil tahu apa yang dia lakukan. Kalau Ordo tahu aku membantu Front, "
"aku sama saja sudah mati... Tapi itu tidak urusanmu. Medis Front memberi aku "
"chip peningkatan untukmu, siap? "

msgid "TXT_RPLY0_SCRIPT02_D22740_YESIM"
msgstr "Ya, aku siap."

msgid "TXT_RYES0_SCRIPT02_D22740_WELLT"
msgstr "Kalau begitu, ini tidak butuh waktu lama. Nah, sudah selesai."

msgid "TXT_DLG_SCRIPT02_D24256_HOWMA"
msgstr "Ada yang bisa kubantu?"

msgid "TXT_RPLY0_SCRIPT02_D24256_MEDPA"
